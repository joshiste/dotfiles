alias gitacf='git add . && git commit --amend --no-edit && git push --force-with-lease && git rev-parse HEAD'
alias gitcleansemver='git tag -d $(git tag -l | grep -v "^v[0-9]*.[0-9]*.[0-9]*")'

alias crcssh='ssh -i ~/.crc/machines/crc/id_ed25519 -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -p 2222 core@127.0.0.1'
